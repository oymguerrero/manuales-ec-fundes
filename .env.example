# =========================================================
# Mi CompañIA · Variables de entorno
# =========================================================
# Copia este archivo a `.env` (sin la extensión `.example`)
# y reemplaza los valores con tus credenciales reales.
#
# El archivo `.env` está en .gitignore — NUNCA se commitea.
# Esta plantilla `.env.example` SÍ se commitea como referencia.
# =========================================================

# ─────────────────────────────────────────────────────────
# Google Cloud · API key
# ─────────────────────────────────────────────────────────
# Usado por:
#   · Cloud Text-to-Speech (audio narrado · voces Neural2/Studio)
#   · Imagen (generación de imágenes "Nano Banana")
#   · Veo (generación de video)
#   · Otras APIs de Google Cloud que el proyecto requiera
#
# Cómo obtenerla:
#   1. Ve a https://console.cloud.google.com/apis/credentials
#   2. Crea o selecciona un proyecto
#   3. Habilita las APIs que vas a usar (TTS, Imagen, Veo, etc.)
#   4. "Crear credenciales" → "Clave de API"
#   5. (Recomendado) Restringe la clave por API y por IP/referer
#
# Formato: cadena alfanumérica que empieza con `AIza...`
GOOGLE_API_KEY=tu-api-key-aqui

# ─────────────────────────────────────────────────────────
# Google Cloud · Service Account (opcional · alternativa OAuth)
# ─────────────────────────────────────────────────────────
# Usar SOLO si necesitas autenticación OAuth en lugar de API key
# (algunas APIs lo exigen, ej. Vertex AI). Apunta a la ruta del JSON
# de la cuenta de servicio. Ese JSON NO debe commitearse.
# GOOGLE_APPLICATION_CREDENTIALS=C:\ruta\a\service-account.json

# ─────────────────────────────────────────────────────────
# ElevenLabs · TTS premium (proveedor principal de audio)
# ─────────────────────────────────────────────────────────
# Usado por:
#   · Narración de secciones (calidad superior a Google TTS Neural2)
#   · Voz de marca "cálida, cercana" del proyecto Mi CompañIA
#
# Cómo obtenerla:
#   1. Crea cuenta en https://elevenlabs.io/
#   2. Ve a Profile (esquina superior derecha) > API Keys
#   3. "Create API Key" · copia el valor
#
# Free tier: ~10,000 caracteres/mes (suficiente para ~5 narraciones de 2 min)
# Plan Starter: $5/mes para 30k chars
ELEVENLABS_API_KEY=tu-elevenlabs-key-aqui

# Voice ID a usar (preset de tu librería)
# Voces multilingüe v2 recomendadas (funcionan bien en español MX):
#   · 21m00Tcm4TlvDq8ikWAM  Rachel       (femenina cálida, default)
#   · EXAVITQu4vr4xnSDxMaL  Bella        (femenina expresiva)
#   · pNInz6obpgDQGcFmaJgB  Adam         (masculina seria)
#   · TxGEqnHWrfWFTfGW9XjX  Josh         (masculina joven)
# Para listar las voces de tu cuenta: GET https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Modelo: eleven_multilingual_v2 maneja español con calidad muy alta
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Voice settings (0.0 - 1.0)
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.0

# ─────────────────────────────────────────────────────────
# Higgsfield (referencia · gestionado por la CLI)
# ─────────────────────────────────────────────────────────
# Higgsfield no usa env var: la sesión la maneja `higgsfield auth login`
# y se guarda en el credential store del SO. Esta línea es solo
# documentación para que sepas que NO necesitas variable de entorno.
# HIGGSFIELD_TOKEN=gestionado-por-cli

# ─────────────────────────────────────────────────────────
# Configuración del proyecto (no secretos · ajustables)
# ─────────────────────────────────────────────────────────
# Idioma de TTS por defecto
TTS_LANGUAGE_CODE=es-MX
TTS_VOICE_NAME=es-US-Neural2-A
TTS_SPEAKING_RATE=0.95

# Directorios
MEDIA_DIR=media
IMG_DIR=img
