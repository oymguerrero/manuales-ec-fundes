# macOS / Windows
.DS_Store
Thumbs.db
desktop.ini

# Editores
.vscode/
.idea/
*.swp
*.swo

# Archivos temporales
*.tmp
*.bak
*~

# OneDrive
*.lnk

# Secretos · credenciales · variables de entorno
# IMPORTANTE: el archivo .env.example SÍ se commitea (es plantilla sin valores reales)
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json
service-account*.json

# Media intermedia (clips crudos de higgsfield antes de ensamblar)
media/raw/

# Archivos de logs locales
*.log
logs/

# Claude Code / Cowork
# Por default ignoramos TODO dentro de .claude/, pero permitimos que los
# agentes, skills y README del equipo SI se compartan via git (son trabajo
# colaborativo). El settings.local.json sigue siendo local (permisos personales).
.claude/*
!.claude/agents/
!.claude/skills/
!.claude/README.md

# Playwright MCP
.playwright-mcp/

# Office: carpetas auxiliares que Word/Excel/PowerPoint crean al previsualizar HTML-en-extensión-ofimática (legacy)
*.files/
~$*

# Carpeta de trabajo local del equipo: drafts, fuentes, material privado
extras/

# Python
__pycache__/
*.pyc
